#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "${GREEN}✔${RESET}  $1"; }
fail() { echo -e "${RED}✘${RESET}  $1"; }

echo -e "\n${BOLD}Running pre-push checks…${RESET}\n"

# ── cargo clippy ──────────────────────────────────────────────────────────────
if ! cargo clippy --features desktop --all-targets -- -D warnings 2>&1; then
    fail "Clippy reported warnings or errors. Fix them before pushing."
    exit 1
fi
pass "cargo clippy"

echo -e "\n${GREEN}All checks passed.${RESET}\n"
